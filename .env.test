# backend service base url, test environment
# VITE_SERVICE_BASE_URL=https://mock.apifox.cn/m1/3109515-0-default
VITE_SERVICE_BASE_URL=http://localhost:8005

# other backend service base url, test environment
VITE_OTHER_SERVICE_BASE_URL= `{
  "mes": "http://localhost:8001",
  "k3cloud": "http://localhost/k3cloud",
  "cosmic": "https://xundie.kdcloud.com"
}`

# 成功状态码
VITE_SERVICE_SUCCESS_CODE=200

# Token 过期码（触发自动刷新 Token）
# 40101 = Access Token 过期
VITE_SERVICE_EXPIRED_TOKEN_CODES=40101

# 直接登出码（静默跳转登录页）
# 40102 = Refresh Token 过期
# 40103 = Token 无效
# 40111 = 会话过期
VITE_SERVICE_LOGOUT_CODES=40102,40103,40111

# 弹窗提示后登出码（显示提示框）
# 40105 = 账户被锁定
# 40106 = 账户被禁用  
# 40110 = 强制登出
# 40112 = 设备数量超限
VITE_SERVICE_MODAL_LOGOUT_CODES=40105,40106,40110,40112